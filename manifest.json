{
  "manifest_version": 3,
  "name": "Light Todo",
  "description": "A clean browser todo list that keeps tasks in local browser storage.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Light Todo",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+X",
        "windows": "Alt+X",
        "mac": "Alt+X",
        "chromeos": "Alt+X",
        "linux": "Alt+X"
      },
      "description": "Open Light Todo"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ]
}
